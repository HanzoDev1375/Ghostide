<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_height="match_parent"
  android:layout_width="match_parent"
  tools:openDrawer="start"
  android:id="@+id/_drawer">

  <androidx.coordinatorlayout.widget.CoordinatorLayout
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="@android:color/transparent"
    android:id="@+id/_coordinator">

    <com.google.android.material.appbar.AppBarLayout
      android:layout_height="wrap_content"
      android:layout_width="match_parent"
      android:background="@android:color/transparent"
      app:liftOnScrollColor="@android:color/transparent"
      app:liftOnScroll="false"
      android:fitsSystemWindows="true"
      android:id="@+id/_app_bar">

      <LinearLayout
        android:layout_height="56dp"
        android:layout_width="match_parent"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
          android:layout_height="35dp"
          android:layout_width="35dp"
          android:scaleType="centerInside"
          android:src="@drawable/ic_more_vert_white"
          android:layout_marginLeft="10dp"
          android:layout_marginRight="6dp"
          android:id="@+id/opendraw" />

        <TextView
          android:layout_height="wrap_content"
          android:layout_width="wrap_content"
          android:gravity="center_vertical|left"
          android:textAppearance="?attr/textAppearanceHeadlineMedium"
          android:textSize="17sp"
          android:layout_weight="1.0"
          android:id="@+id/githubusernametv"
          android:text="@string/app_name" />

        <ImageView
          android:layout_height="35dp"
          android:layout_width="35dp"
          android:scaleType="centerInside"
          android:src="@drawable/app_icon"
          android:layout_marginLeft="10dp"
          android:layout_marginRight="7dp"
          android:id="@+id/githubavataric" />

        <ImageView
          android:layout_height="40dp"
          android:layout_width="40dp"
          android:scaleType="centerInside"
          android:src="@drawable/ic_search_black_24"
          android:background="?attr/selectableItemBackground"
          android:layout_marginLeft="5dp"
          android:layout_marginRight="10dp"
          android:tint="?@attr/colorPrimary"
          android:id="@+id/searchfiledir" />

      </LinearLayout>

      <com.ninjacoder.jgit.search.SearchBar
        android:layout_height="56dp"
        android:layout_width="match_parent"
        android:visibility="gone"
        android:id="@+id/searchbar" />



    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
      android:layout_height="match_parent"
      android:layout_width="match_parent"
      app:layout_behavior="@string/appbar_scrolling_view_behavior"
      android:orientation="vertical"
      android:fitsSystemWindows="true">
      <androidx.recyclerview.widget.RecyclerView
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:padding="4dp"
        android:minHeight="40dp"
        android:visibility="visible"
        android:id="@+id/treerv" />

      <LinearLayout
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:id="@+id/view_filedir">

        <FrameLayout
          android:layout_height="0dp"
          android:layout_width="match_parent"
          android:layout_weight="1">

          <androidx.recyclerview.widget.RecyclerView
            android:layout_height="match_parent"
            android:layout_width="match_parent"
            android:padding="8dp"
            android:id="@+id/recyclerview2" />

          <ir.ninjacoder.prograsssheet.view.EmptyState
            android:layout_height="match_parent"
            android:layout_width="match_parent"
            app:show="false"
            android:gravity="center"
            app:emptyStateButtonText="This list Empty"
            android:id="@+id/emptyview"
            android:layout_gravity="center" />

          <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:visibility="gone"
            android:indeterminate="true"
            app:trackThickness="5dp"
            android:id="@+id/filedir_bar"
            android:layout_gravity="center" />

        </FrameLayout>

      </LinearLayout>

    </LinearLayout>

    <ninja.coder.appuploader.main.ViewDownloder
      android:layout_height="wrap_content"
      android:layout_width="match_parent"
      android:visibility="gone"
      android:id="@+id/downloder"
      android:layout_gravity="bottom|right"
      android:layout_marginBottom="16dp" />

    <ir.ninjacoder.ghostide.core.widget.ExrtaFab
      android:layout_height="80dp"
      android:layout_width="80dp"
      android:layout_marginBottom="50dp"
      android:clickable="true"
      android:elevation="8dp"
      android:layout_marginRight="20dp"
      app:fabSize="normal"
      android:id="@+id/fabAdd"
      android:layout_gravity="bottom|right" />
    <LinearLayout
      android:layout_height="wrap_content"
      android:layout_width="match_parent"
      android:layout_marginBottom="72dp"
      android:visibility="gone"
      android:padding="8dp"
      android:orientation="horizontal"
      android:id="@+id/viewChild"
      android:layout_gravity="right|bottom">

      <LinearLayout
        android:layout_height="match_parent"
        android:layout_width="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_horizontal|center_vertical"
        android:padding="8dp"
        android:orientation="vertical"
        android:id="@+id/mdel">

        <ImageView
          android:layout_height="25dp"
          android:layout_width="25dp"
          android:scaleType="centerInside"
          android:src="@drawable/delete" />

        <TextView
          android:layout_height="wrap_content"
          android:layout_width="wrap_content"
          android:padding="8dp"
          android:textSize="12sp"
          android:text="remved" />

      </LinearLayout>

    </LinearLayout>

    <ir.ninjacoder.ghostide.core.mult.MultiSelectionActionView
      android:layout_height="wrap_content"
      android:layout_width="match_parent"
      android:layout_marginBottom="65dp"
      android:visibility="gone"
      android:layout_marginEnd="10dp"
      android:elevation="16dp"
      android:layout_marginStart="10dp"
      android:id="@+id/multiSelectionActions"
      android:layout_gravity="right|bottom" />
  </androidx.coordinatorlayout.widget.CoordinatorLayout>

  <ir.ninjacoder.ghostide.core.layoutmanager.NavigationViewCompnet
    android:layout_height="match_parent"
    android:layout_width="300dp"
    android:scrollbars="none"
    app:headerLayout="@layout/header"
    android:id="@+id/navs"
    android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
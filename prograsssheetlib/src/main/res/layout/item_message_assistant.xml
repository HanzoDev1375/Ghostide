<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="wrap_content"
    android:layout_width="match_parent"
    android:padding="8dp"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        app:strokeColor="?attr/colorOutlineVariant"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:cardCornerRadius="12dp"
        app:contentPadding="12dp"
        android:id="@+id/messageCard"
        android:layout_gravity="start">

        <LinearLayout
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:orientation="vertical"
            android:minWidth="200dp">

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_marginBottom="8dp"
                android:orientation="vertical"
                android:id="@+id/reasoningContainer">

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="0dp"
                        android:textSize="12sp"
                        android:textColor="?attr/colorPrimary"
                        android:layout_weight="1"
                        android:text="تفکر"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_height="24dp"
                        android:layout_width="24dp"
                        android:src="@drawable/ic_expand_less"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:id="@+id/toggleReasoningButton" />

                </LinearLayout>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:background="@drawable/bg_reasoning"
                    android:padding="12dp"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="4dp"
                    android:id="@+id/reasoningText" />

            </LinearLayout>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:lineSpacingExtra="4dp"
                android:id="@+id/messageText" />

            <View
                android:layout_height="20dp"
                android:layout_width="40dp"
                android:visibility="gone"
                android:background="@drawable/typing_dots"
                android:layout_marginTop="8dp"
                android:id="@+id/typingIndicator" />

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:gravity="end"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:id="@+id/timeText" />

                <ImageView
                    android:layout_height="24dp"
                    android:layout_width="24dp"
                    android:visibility="gone"
                    android:src="@drawable/ic_copy"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="8dp"
                    android:id="@+id/copyButton" />

                <ImageView
                    android:layout_height="24dp"
                    android:layout_width="24dp"
                    android:visibility="gone"
                    android:src="@drawable/ic_refresh"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="4dp"
                    android:id="@+id/regenerateButton" />

                <ProgressBar
                    android:layout_height="24dp"
                    android:layout_width="24dp"
                    android:visibility="gone"
                    android:layout_marginStart="4dp"
                    android:id="@+id/regenerateProgress" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
